# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/.open-next/
/.wrangler/

# misc
.DS_Store
*.pem

# editor (keep shared workspace config, ignore personal files)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
.dev.vars*
!.dev.vars.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
cloudflare-env.d.ts
.pnpm-store

# claude
.claude